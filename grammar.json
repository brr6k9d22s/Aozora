[
  {
    "id": "G0001",
    "grammar": "ほうがいいです",
    "purpose": "表达建议",
    "connection": [
      "Vた＋ほうがいいです",
      "Vない＋ほうがいいです"
    ],
    "meaning": [
      {
        "pattern": "Vた",
        "text": "建议做……"
      },
      {
        "pattern": "Vない",
        "text": "建议不要……"
      }
    ],
    "why": "た形强调“做了会更好”，是建议而非命令。",
    "example": {
      "jp": "疲（つか）れた時（とき）は、早（はや）く寝（ね）たほうがいいです。",
      "cn": "累的时候最好早点睡。"
    }
  }
]